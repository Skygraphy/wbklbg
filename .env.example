# Resend – Email service for contact form
# Get your API key at https://resend.com
RESEND_API_KEY=re_...

# The verified sender address in Resend (domain must be verified)
# During testing you can use: onboarding@resend.dev
RESEND_FROM_EMAIL=kontakt@wimmelbuch-klosterneuburg.at

# Where contact form emails are delivered (Ines's inbox)
RESEND_TO_EMAIL=ines@example.com

# Neon PostgreSQL – for popup stand dates
# Get your connection string at https://neon.tech
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Secret for the admin popup-stands POST endpoint (pick any random string)
POPUP_STANDS_SECRET=your-secret-here
